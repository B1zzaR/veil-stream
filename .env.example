# ============================================================
# Veil Stream — конфигурация окружения
# Скопируйте в .env и заполните своими значениями
# ============================================================

# --- Порты ---
HTTP_PORT=80
HTTPS_PORT=443

# --- База данных ---
POSTGRES_DB=veil
POSTGRES_USER=veil
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# --- JWT (минимум 16 символов, рекомендуется 32+) ---
JWT_SECRET=CHANGE_ME_random_32_char_string_here

# --- Администратор (логин/пароль для веб-интерфейса) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password

# --- Сервер ---
PORT=8080
MEDIA_PATH=/media
ENV=production
